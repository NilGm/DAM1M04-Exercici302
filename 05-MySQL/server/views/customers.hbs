{{> header}}
{{> menu}}

<main class="container">
    <h1>Llistat de Clients</h1>
    <div class="grid">
        {{#each customers}}
        <div class="card customer-card">
            <h3>{{this.first_name}} {{this.last_name}}</h3>
            <h4>Últims lloguers:</h4>
            <ul>
                {{#each rentals}}
                <li><strong>{{this.title}}</strong> ({{this.rental_date}})</li>
                {{else}}
                <li>Cap lloguer trobat.</li>
                {{/each}}
            </ul>
        </div>
        {{/each}}
    </div>
</main>

{{> footer}}