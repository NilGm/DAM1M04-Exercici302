{{> header}}
{{> menu}}

<main class="container">
    <h1>Benvinguts a Sakila</h1>

    <section>
        <h2>🎬 Top 5 Movies</h2>
        <div class="grid">
            {{#each movies}}
            <article class="card">
                <h3>{{this.title}}</h3>
                <p>Any: {{this.release_year}}</p>
            </article>
            {{/each}}
        </div>
    </section>

    <section>
        <h2>📂 Categories</h2>
        <ul class="category-list">
            {{#each categories}}
            <li>{{this.name}}</li>
            {{/each}}
        </ul>
    </section>
</main>

{{> footer}}